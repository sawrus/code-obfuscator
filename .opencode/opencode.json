{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "model-checker",
    "sound-notification",
    "telegram-notification"
  ],
  "agent": {
    "product-owner": {
      "description": "Main coordinator for feature development workflow",
      "mode": "primary",
      "model": "google/antigravity-claude-sonnet-4-6",
      "fallback": [
        "openai/gpt-5.2"
      ],
      "permission": {
        "task": {
          "pm": "allow",
          "team-lead": "allow",
          "designer": "allow",
          "developer": "allow",
          "qa": "allow"
        }
      }
    },
    "pm": {
      "description": "Project Manager - coordinates workflow",
      "mode": "subagent",
      "model": "google/antigravity-claude-sonnet-4-6",
      "fallback": [
        "openai/gpt-5.2"
      ],
      "permission": {
        "task": {
          "team-lead": "allow",
          "designer": "allow",
          "developer": "allow",
          "qa": "allow"
        }
      }
    },
    "team-lead": {
      "description": "Team Lead - planning and code review",
      "mode": "subagent",
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "fallback": [
        "openai/gpt-5.3-codex"
      ],
      "permission": {
        "task": {
          "developer": "allow",
          "qa": "allow"
        }
      }
    },
    "developer": {
      "description": "Developer - implements code",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "fallback": [
        "google/gemini-3.1-pro-preview-customtools"
      ]
    },
    "qa": {
      "description": "QA Engineer - runs tests",
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "fallback": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "designer": {
      "description": "Designer - UI/UX validation",
      "mode": "subagent",
      "model": "google/antigravity-claude-sonnet-4-6",
      "fallback": [
        "google/antigravity-gemini-3.1-pro"
      ]
    }
  }
}
